<launch>
  <arg name="pcd" default="$(find fast_lio)/PCD/scans_ds.pcd" />
  <arg name="frame" default="camera_init" />
  <arg name="stride" default="10" />
  <node pkg="pcl_ros" type="pcd_to_pointcloud" name="pcd_to_pointcloud" args="$(arg pcd) 1.0" output="screen">
    <param name="frame_id" value="$(arg frame)" />
    <param name="latch" value="true" />
  </node>
  <node pkg="fast_lio" type="thin_cloud.py" name="thin_pcd_cloud" output="screen">
    <param name="stride" value="$(arg stride)" />
  </node>
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find fast_lio)/rviz_cfg/fastlio2_map_only.rviz" />
</launch>
